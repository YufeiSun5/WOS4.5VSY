  "updateScriptSample": "/*\r\n * 创建人：tian.he\r\n * 函数名：updatePUInstance\r\n * 描述：更新生产单元实例\r\n * 步骤：\r\n * 参数：\r\n * 返回值：\r\n */\r\n\r\ndebugger\r\n\r\n// 声明call函数常量\r\nconst CALL_BY_NAME = 2;\r\nconst API_TYPE = 21001; // 接口类型标识\r\nconst TIMEOUT = 1000 * 60 * 5; // 接口请求超时时间\r\nconst PARAM_PUBLIC = new StringMap({\r\n    \"cloudID\": $Variable.cloudID,\r\n    \"type\": API_TYPE,\r\n    \"timeout\": TIMEOUT\r\n});\r\n\r\n// 消息提示窗函数\r\nfunction _Infor(massage, type) {\r\n    var options = {\r\n        message: massage,\r\n        type: type,\r\n        duration: 3000,\r\n        showClose: true\r\n    };\r\n    ShowMessage(options);\r\n}\r\n\r\n// --------------------------------遮罩层校验状态---------------------------------\r\n// 基于 Promise 的 sleep 函数\r\nfunction sleep(ms) {\r\n    return new Promise(resolve => setTimeout(resolve, ms));\r\n}\r\n\r\n// 获取期望结果函数\r\nfunction getExpectedResult(command) {\r\n    let result = \"\";\r\n    switch (command) {\r\n        case '更新':\r\n            result = \"已启动\";\r\n            break;\r\n        default:\r\n            break;\r\n    }\r\n    return result;\r\n}\r\n\r\n// 查询时空对象状态函数\r\nf"
}